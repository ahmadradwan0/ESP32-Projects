void handleRoot() {
  server.send(200, "text/html", HTML_PAGE);
}

void handleLed1On() {
  digitalWrite(LED1_PIN, HIGH);
  screen.Clear();
  screen.ShowText("LED1:", 0, 0, 1);
  screen.ShowText("ON", 0, 16, 3);
  screen.Show();
  server.send(200, "text/plain", "ON");
}

void handleLed1Off() {
  digitalWrite(LED1_PIN, LOW);
  screen.Clear();
  screen.ShowText("LED1:", 0, 0, 1);
  screen.ShowText("OFF", 0, 16, 3);
  screen.Show();
  server.send(200, "text/plain", "OFF");
}

void handleClear() {
  screen.Clear();
  screen.Show();
  server.send(200, "text/plain", "Cleared");
}

void handleText() {
  String text = server.arg("plain");
  text.trim();

  screen.Clear();
  screen.ShowText("Message:", 0, 0, 1);
  screen.ShowText(text, 0, 16, 2);
  screen.Show();

  server.send(200, "text/plain", "OK");
}

void setup() {
  if (!screen.Init()) for(;;);

  pinMode(LED1_PIN, OUTPUT);
  digitalWrite(LED1_PIN, LOW);

  screen.Clear();
  screen.ShowText("WiFi:", 0, 0, 1);
  screen.ShowText("Connecting...", 0, 16, 2);
  screen.Show();

  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
  }

  server.on("/", handleRoot);
  server.on("/led1/on", handleLed1On);
  server.on("/led1/off", handleLed1Off);
  server.on("/clear", handleClear);
  server.on("/text", HTTP_POST, handleText);
  server.begin();

  screen.Clear();
  screen.ShowText("Open in browser:", 0, 0, 1);
  screen.ShowText(WiFi.localIP().toString(), 0, 16, 1);
  screen.Show();
}

void loop() {
  server.handleClient();
}