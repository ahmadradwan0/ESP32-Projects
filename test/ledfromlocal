#include <Arduino.h>
#include <Screen.h>
#include <WiFi.h>
#include <WebServer.h>

const char* WIFI_SSID = "IoT";
const char* WIFI_PASSWORD = "Qwerty@384#";

Screen screen;
WebServer server(80);
#define LED1_PIN 2

const char HTML_PAGE[] = R"rawliteral(
