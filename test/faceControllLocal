#include <Arduino.h>
#include <WiFi.h>
#include <WebServer.h>
#include <Face.h>

const char* WIFI_SSID = "IoT";
const char* WIFI_PASSWORD = "Qwerty@384#";  // ← update this

Face face;
WebServer server(80);

bool cyclopsOn = false;
bool sweatOn = false;
bool curiousOn = true;

const char HTML_PAGE[] = R"rawliteral(
