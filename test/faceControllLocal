void handleRoot()    { server.send(200, "text/html", HTML_PAGE); }

void handleHappy()   { face.Happy();    server.send(200, "text/plain", "ok"); }
void handleAngry()   { face.Angry();    server.send(200, "text/plain", "ok"); }
void handleTired()   { face.Tired();    server.send(200, "text/plain", "ok"); }
void handleNeutral() { face.Neutral();  server.send(200, "text/plain", "ok"); }

void handleUp()      { face.LookUp();     server.send(200, "text/plain", "ok"); }
void handleDown()    { face.LookDown();   server.send(200, "text/plain", "ok"); }
void handleLeft()    { face.LookLeft();   server.send(200, "text/plain", "ok"); }
void handleRight()   { face.LookRight();  server.send(200, "text/plain", "ok"); }
void handleCenter()  { face.LookCenter(); server.send(200, "text/plain", "ok"); }

void handleBlink()     { face.Blink();     server.send(200, "text/plain", "ok"); }
void handleWinkLeft()  { face.WinkLeft();  server.send(200, "text/plain", "ok"); }
void handleWinkRight() { face.WinkRight(); server.send(200, "text/plain", "ok"); }
void handleLaugh()     { face.Laugh();     server.send(200, "text/plain", "ok"); }
void handleConfused()  { face.Confused();  server.send(200, "text/plain", "ok"); }

void handleToggleCyclops() {
  cyclopsOn = !cyclopsOn;
  face.SetCyclops(cyclopsOn);
  server.send(200, "text/plain", cyclopsOn ? "on" : "off");
}
void handleToggleSweat() {
  sweatOn = !sweatOn;
  face.SetSweat(sweatOn);
  server.send(200, "text/plain", sweatOn ? "on" : "off");
}
void handleToggleCurious() {
  curiousOn = !curiousOn;
  face.SetCurious(curiousOn);
  server.send(200, "text/plain", curiousOn ? "on" : "off");
}

void setup() {
  if (!face.Init()) for(;;);
  face.SetCurious(true);  // matches default toggle state in HTML

  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
  }

  server.on("/", handleRoot);

  server.on("/mood/happy", handleHappy);
  server.on("/mood/angry", handleAngry);
  server.on("/mood/tired", handleTired);
  server.on("/mood/neutral", handleNeutral);

  server.on("/look/up", handleUp);
  server.on("/look/down", handleDown);
  server.on("/look/left", handleLeft);
  server.on("/look/right", handleRight);
  server.on("/look/center", handleCenter);

  server.on("/blink", handleBlink);
  server.on("/wink/left", handleWinkLeft);
  server.on("/wink/right", handleWinkRight);
  server.on("/laugh", handleLaugh);
  server.on("/confused", handleConfused);

  server.on("/toggle/cyclops", handleToggleCyclops);
  server.on("/toggle/sweat", handleToggleSweat);
  server.on("/toggle/curious", handleToggleCurious);

  server.begin();
}

void loop() {
  face.Update();
  server.handleClient();
}